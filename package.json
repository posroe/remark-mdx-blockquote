{
    "name": "remark-mdx-blockquote",
    "version": "1.0.2",
    "description": "A remark plugin that converts GitHub-style alert blockquotes (e.g. > [!NOTE]) into <blockquote> elements with a data-callout attribute.",
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "test": "vitest run",
        "test:watch": "vitest",
        "prepublishOnly": "bun run build"
    },
    "devDependencies": {
        "@types/mdast": "^4.0.4",
        "@types/node": "^25.6.0",
        "remark-parse": "^11.0.0",
        "tsup": "^8.5.1",
        "typescript": "^5",
        "vitest": "^4.1.5",
        "unified": "^11.0.5"
    },
    "dependencies": {
        "unist-util-visit": "^5.1.0"
    },
    "peerDependencies": {
        "unified": ">=11.0.5"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/posroe/remark-mdx-blockquote.git"
    },
    "license": "MIT",
    "keywords": [
        "mdx",
        "blockquote",
        "remark",
        "unified",
        "markdown",
        "remark-plugin",
        "remark-mdx-blockquote",
        "alert",
        "admonition",
        "plugin"
    ]
}